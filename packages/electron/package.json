{
  "name": "@photo-quest/electron",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "dependencies": {
    "electron-updater": "^6.3.0"
  },
  "devDependencies": {
    "electron": "^35.7.5",
    "electron-builder": "^25.1.8"
  },
  "repository": "https://github.com/yentsun/photo-quest",
  "build": {
    "appId": "com.photoquest.app",
    "productName": "Photo Quest",
    "asar": false,
    "directories": {
      "output": "../../dist-electron"
    },
    "files": [
      "main.js",
      "!node_modules"
    ],
    "extraResources": [
      {
        "from": "../../node_modules",
        "to": "node_modules",
        "filter": [
          "**/*",
          "!.cache/**",
          "!**/.bin/**"
        ]
      },
      {
        "from": "../server",
        "to": "server",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../worker",
        "to": "worker",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../shared",
        "to": "shared",
        "filter": [
          "**/*",
          "!node_modules/**"
        ]
      },
      {
        "from": "../web/dist",
        "to": "web/dist"
      }
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "assets/icon.ico"
    },
    "publish": {
      "provider": "github"
    }
  }
}
