{
  "name": "photo-quest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm run --parallel dev:web dev:server dev:worker",
    "dev:web": "pnpm --filter @photo-quest/web dev",
    "dev:server": "pnpm --filter @photo-quest/server dev",
    "dev:worker": "pnpm --filter @photo-quest/worker dev",
    "build": "pnpm --filter @photo-quest/web build"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild"
    ]
  }
}
