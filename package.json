{
  "name": "photo-quest",
  "version": "0.3.1",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @photo-quest/web --filter @photo-quest/server dev",
    "dev:web": "pnpm --filter @photo-quest/web dev",
    "dev:server": "pnpm --filter @photo-quest/server dev",
    "build": "pnpm --filter @photo-quest/web build",
    "start": "pnpm --filter @photo-quest/server start",
    "test": "pnpm --filter @photo-quest/server test",
    "dev:electron": "npm --prefix packages/electron install && pnpm --filter @photo-quest/electron start",
    "electron:build": "pnpm build && pnpm --filter @photo-quest/electron build",
    "make-icons": "node scripts/make-icons.mjs"
  },
  "devDependencies": {
    "sharp": "^0.34.5"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "ffmpeg-static",
      "sharp"
    ]
  }
}
