{
  "name": "photo-quest",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "pnpm --parallel --filter @photo-quest/pwa --filter @photo-quest/server --filter @photo-quest/worker dev",
    "dev:pwa": "pnpm --filter @photo-quest/pwa dev",
    "dev:server": "pnpm --filter @photo-quest/server dev",
    "dev:worker": "pnpm --filter @photo-quest/worker dev",
    "build": "pnpm --filter @photo-quest/pwa build",
    "start": "pnpm --parallel --filter @photo-quest/server --filter @photo-quest/worker start",
    "test": "pnpm --filter @photo-quest/server test"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "better-sqlite3",
      "esbuild",
      "sharp"
    ]
  }
}
